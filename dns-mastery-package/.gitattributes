# Force LF line endings for everything text-based — prevents the CRLF
# zone-file trap documented in file 16 if this repo is ever cloned on
# Windows and the lab files are edited from within it.
* text=auto eol=lf
*.md text eol=lf
*.tsv text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
